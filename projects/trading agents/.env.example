# ── LLM provider (default: anthropic) ─────────────────────────────────────────
# TRADING_LLM_PROVIDER=deepseek   # or: anthropic

ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ── Market data (optional, improves A-share data quality) ─────────────────────

# Tushare — A-share fundamentals & stock info (free token at tushare.pro)
# With token: daily_basic (PE/PB), fina_indicator (ROE/margins), income statement
TUSHARE_TOKEN=

# Alpha Vantage — US/HK price history fallback when yfinance is rate-limited
# Free key at alphavantage.co (25 requests/day on free tier)
ALPHA_VANTAGE_KEY=
